datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(EMPLOYEE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  invoices     Invoice[]
}

enum Role {
  ADMIN
  FINANCE_MANAGER
  EMPLOYEE
  AUDITOR
}

model Invoice {
  id                Int           @id @default(autoincrement())
  invoiceNumber     String
  invoiceDate       DateTime?
  vendorName        String?
  currency          String        @default("USD")
  subtotal          Float         @default(0.0)
  discount          Float         @default(0.0)
  tax               Float         @default(0.0)
  shipping          Float         @default(0.0)
  grandTotal        Float         @default(0.0)
  billingPeriod     String?
  billingMonth      String?
  environment       String?
  awsAccount        String?
  status            InvoiceStatus @default(DRAFT)
  aiConfidenceScore Float         @default(0.0)
  originalFilePath  String?
  extractedJson     String?
  editedJson        String?
  metadata          String?
  currentVersion    Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  creatorId         Int?
  creator           User?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  projectId         Int?
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]
  attachments       Attachment[]
}

enum InvoiceStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PAID
  UNPAID
  SCANNED
  SAVED
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float   @default(1.0)
  unitPrice   Float   @default(0.0)
  amount      Float   @default(0.0)
}

model Attachment {
  id        Int      @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  filePath  String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
}

model Project {
  id              Int             @id @default(autoincrement())
  name            String
  code            String          @unique
  description     String?
  owner           String
  businessUnit    String?
  status          String          @default("ACTIVE")
  costCenter      String?
  tags            String?
  billingProvider String          @default("AWS")
  awsAccount      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  resources       CloudResource[]
  invoices        Invoice[]
}

model CloudResource {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  instanceName     String
  resourceType     String
  instanceType     String?
  vcpus            Int      @default(0)
  memory           Float    @default(0.0)
  storage          Float    @default(0.0)
  availabilityZone String?
  privateIp        String?
  publicIp         String?
  os               String?
  monitoring       Boolean  @default(false)
  monthlyCost      Float    @default(0.0)
  billingSeats     Int?
  billingUnit      String?
  status           String   @default("RUNNING")
  tags             String?
  environment      String   @default("Production")
  region           String   @default("us-east-1")
  tool             String   @default("AWS")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
